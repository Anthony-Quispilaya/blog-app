EXPO_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY
# Public web base URL (your deployed site). Used for sharing links from native.
# For local web dev you can temporarily set this to http://localhost:8081
EXPO_PUBLIC_WEB_URL=https://YOUR_DOMAIN.com
EXPO_PUBLIC_OPENAI_API_KEY=YOUR_OPENAI_API_KEY

# Server-side only (set in Supabase Edge Function secrets, NOT in client env)
OPENAI_API_KEY=YOUR_OPENAI_API_KEY
WHISPER_SERVICE_URL=http://localhost:8787/transcribe
